# ChurnGuard — configuration de l'environnement
# Copiez ce fichier en .env et ajustez les valeurs.
#
#   cp .env.example .env

# Chemins de données
CHURNGUARD_MODEL_PATH=models/best_model.pkl
CHURNGUARD_INPUT_CSV=data/telco_churn.csv
CHURNGUARD_OUTPUT_CSV=data/predictions.csv

# API
API_VERSION=1.0.0
MODEL_NAME=churn_model_v1
MODEL_URI=models/best_model.pkl
MODEL_VERSION=best_model

# Authentification Basic auth (OBLIGATOIRE à changer en production)
API_USERNAME=admin
API_PASSWORD=changeme

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Inférence — seuil de décision churn (0.0–1.0)
CHURN_THRESHOLD=0.5

# Logging
API_LOG_LEVEL=INFO

# Sécurité — décommenter en production pour désactiver le fallback pickle
# CHURNGUARD_ENV=production
